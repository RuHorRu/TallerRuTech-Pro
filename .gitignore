```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.py~

# Database
*.db
*.sqlite
*.sqlite3

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE specific
.vscode/
.idea/

# Build artifacts
dist/
build/
target/
.mypy_cache/
.pytest_cache/

# Images
images/
```